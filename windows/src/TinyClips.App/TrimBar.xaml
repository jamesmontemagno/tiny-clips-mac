<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="TinyClips.App.TrimBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Height="44"
    MinWidth="80"
    Background="Transparent"
    mc:Ignorable="d">

    <!--  Single-line trim track (dimmed groove + accent selection + two handles + playhead).  -->
    <Canvas x:Name="PartCanvas" Background="Transparent">
        <Border
            x:Name="TrackBg"
            Background="{ThemeResource ControlStrongFillColorDefaultBrush}"
            CornerRadius="6" />
        <Border
            x:Name="ActiveRegion"
            Background="{ThemeResource AccentFillColorDefaultBrush}"
            CornerRadius="4"
            Opacity="0.35" />
        <Rectangle
            x:Name="Playhead"
            Width="2"
            Fill="{ThemeResource TextFillColorPrimaryBrush}"
            RadiusX="1"
            RadiusY="1" />
        <Border
            x:Name="StartHandle"
            Background="{ThemeResource AccentFillColorDefaultBrush}"
            CornerRadius="5">
            <Rectangle
                Width="3"
                Height="14"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Fill="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                Opacity="0.9"
                RadiusX="1.5"
                RadiusY="1.5" />
        </Border>
        <Border
            x:Name="EndHandle"
            Background="{ThemeResource AccentFillColorDefaultBrush}"
            CornerRadius="5">
            <Rectangle
                Width="3"
                Height="14"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Fill="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                Opacity="0.9"
                RadiusX="1.5"
                RadiusY="1.5" />
        </Border>
    </Canvas>
</UserControl>
