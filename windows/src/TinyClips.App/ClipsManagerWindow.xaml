<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TinyClips.App.ClipsManagerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TinyClips.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:TinyClips.Core.Models"
    Title="Tiny Clips — Clips Manager"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Custom title bar  -->
        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Height="48"
            Padding="16,0">
            <TextBlock
                VerticalAlignment="Center"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="Clips Manager" />
        </Grid>

        <!--  Toolbar  -->
        <Grid
            Grid.Row="1"
            Padding="24,8,24,8"
            ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                VerticalAlignment="Center"
                Style="{StaticResource TitleTextBlockStyle}"
                Text="Your clips" />

            <ComboBox
                x:Name="FilterComboBox"
                Grid.Column="1"
                Width="160"
                VerticalAlignment="Center"
                AutomationProperties.AutomationId="ClipsFilterComboBox"
                AutomationProperties.Name="Filter clips"
                Header=""
                SelectedIndex="0"
                SelectionChanged="OnFilterChanged">
                <ComboBoxItem Content="All clips" />
                <ComboBoxItem Content="Favorites" />
                <ComboBoxItem Content="Screenshots" />
                <ComboBoxItem Content="Videos" />
                <ComboBoxItem Content="GIFs" />
            </ComboBox>

            <Button
                Grid.Column="2"
                VerticalAlignment="Center"
                AutomationProperties.AutomationId="ClipsRefreshButton"
                AutomationProperties.Name="Refresh clips"
                Click="OnRefreshClicked">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE72C;" />
                    <TextBlock Text="Refresh" />
                </StackPanel>
            </Button>
        </Grid>

        <!--  Empty state  -->
        <StackPanel
            x:Name="EmptyState"
            Grid.Row="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="12"
            Visibility="Collapsed">
            <FontIcon
                FontFamily="{StaticResource SymbolThemeFontFamily}"
                FontSize="48"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Glyph="&#xEB9F;" />
            <TextBlock
                HorizontalAlignment="Center"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="No clips yet" />
            <TextBlock
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource BodyTextBlockStyle}"
                Text="Captures you take will show up here." />
        </StackPanel>

        <!--  Clips grid  -->
        <GridView
            x:Name="ClipsGrid"
            Grid.Row="2"
            Padding="24,8,24,24"
            AutomationProperties.AutomationId="ClipsGridView"
            AutomationProperties.Name="Clips library"
            IsItemClickEnabled="True"
            ItemClick="OnClipClicked"
            SelectionMode="None">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="local:ClipTile">
                    <Grid
                        Width="220"
                        Margin="8"
                        Padding="0,0,0,8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{ThemeResource OverlayCornerRadius}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="124" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Preview  -->
                        <Border
                            Grid.Row="0"
                            Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                            CornerRadius="8,8,0,0">
                            <Image
                                Source="{x:Bind Preview}"
                                Stretch="UniformToFill"
                                Visibility="{x:Bind PreviewVisibility}" />
                        </Border>
                        <FontIcon
                            Grid.Row="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                            FontSize="40"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Glyph="&#xE714;"
                            Visibility="{x:Bind PlaceholderVisibility}" />
                        <FontIcon
                            Grid.Row="0"
                            Margin="8"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                            FontSize="16"
                            Foreground="{ThemeResource SystemFillColorCautionBrush}"
                            Glyph="&#xE735;"
                            Visibility="{x:Bind FavoriteVisibility}" />

                        <!--  Metadata + actions  -->
                        <Grid
                            Grid.Row="1"
                            Margin="12,8,8,0"
                            ColumnSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock
                                    MaxLines="1"
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    Text="{x:Bind FileName}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{x:Bind FileName}" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{x:Bind SizeDisplay}" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                Width="36"
                                Height="36"
                                Padding="0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Clip actions"
                                Background="Transparent"
                                BorderThickness="0">
                                <FontIcon
                                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                                    FontSize="16"
                                    Glyph="&#xE712;" />
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            Click="OnOpenClip"
                                            Tag="{x:Bind FilePath}"
                                            Text="Open">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8A7;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem
                                            Click="OnRevealClip"
                                            Tag="{x:Bind FilePath}"
                                            Text="Show in Explorer">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xED25;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem
                                            Click="OnCopyClip"
                                            Tag="{x:Bind FilePath}"
                                            Text="Copy">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8C8;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator />
                                        <MenuFlyoutItem
                                            Click="OnToggleFavorite"
                                            Tag="{x:Bind FilePath}"
                                            Text="Toggle favorite">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE734;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem
                                            Click="OnUploadClip"
                                            Tag="{x:Bind FilePath}"
                                            Text="Upload &amp; copy link">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE898;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator />
                                        <MenuFlyoutItem
                                            Click="OnDeleteClip"
                                            Tag="{x:Bind FilePath}"
                                            Text="Delete">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE74D;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Window>
