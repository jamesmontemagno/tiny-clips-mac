<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="TinyClips.App.CapturePickerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" Background="Transparent">
        <Border
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Padding="14,8"
            Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource OverlayCornerRadius}">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon
                    x:Name="ModeIcon"
                    VerticalAlignment="Center"
                    FontFamily="Segoe Fluent Icons"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Glyph="&#xE722;" />
                <TextBlock
                    x:Name="ModeLabel"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="Screenshot" />

                <Rectangle
                    Width="1"
                    Height="22"
                    Margin="2,0"
                    Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <Button
                    x:Name="RegionButton"
                    AutomationProperties.AutomationId="CaptureRegionButton"
                    AutomationProperties.Name="Capture region"
                    Click="OnRegion"
                    Style="{StaticResource AccentButtonStyle}"
                    ToolTipService.ToolTip="Select a region (R)">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe Fluent Icons" FontSize="14" Glyph="&#xE7A8;" />
                        <TextBlock Text="Region" />
                    </StackPanel>
                </Button>

                <Button
                    x:Name="ScreenButton"
                    AutomationProperties.AutomationId="CaptureScreenButton"
                    AutomationProperties.Name="Capture screen"
                    Click="OnScreen"
                    ToolTipService.ToolTip="Full screen (S)">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe Fluent Icons" FontSize="14" Glyph="&#xE7F4;" />
                        <TextBlock Text="Screen" />
                    </StackPanel>
                </Button>

                <Button
                    x:Name="WindowButton"
                    AutomationProperties.AutomationId="CaptureWindowButton"
                    AutomationProperties.Name="Capture window"
                    Click="OnWindow"
                    ToolTipService.ToolTip="Select a window (W)">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe Fluent Icons" FontSize="14" Glyph="&#xE737;" />
                        <TextBlock Text="Window" />
                    </StackPanel>
                </Button>

                <Rectangle
                    Width="1"
                    Height="22"
                    Margin="2,0"
                    Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <DropDownButton
                    x:Name="TimerButton"
                    AutomationProperties.AutomationId="CaptureTimerButton"
                    AutomationProperties.Name="Countdown timer"
                    ToolTipService.ToolTip="Countdown before capture">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe Fluent Icons" FontSize="13" Glyph="&#xE916;" />
                        <TextBlock x:Name="TimerLabel" Text="Off" />
                    </StackPanel>
                    <DropDownButton.Flyout>
                        <MenuFlyout x:Name="TimerFlyout" />
                    </DropDownButton.Flyout>
                </DropDownButton>

                <Button
                    x:Name="CancelButton"
                    AutomationProperties.AutomationId="CaptureCancelButton"
                    AutomationProperties.Name="Cancel capture"
                    Click="OnCancel"
                    ToolTipService.ToolTip="Cancel (Esc)">
                    <FontIcon FontFamily="Segoe Fluent Icons" FontSize="12" Glyph="&#xE711;" />
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
