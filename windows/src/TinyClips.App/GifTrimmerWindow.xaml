<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TinyClips.App.GifTrimmerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TinyClips.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Tiny Clips — Trim GIF"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Height="48"
            Padding="16,0">
            <TextBlock
                VerticalAlignment="Center"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="Trim GIF" />
        </Grid>

        <!--  Preview  -->
        <Grid
            Grid.Row="1"
            Margin="16,0,16,16"
            Background="{ThemeResource SubtleFillColorTertiaryBrush}"
            CornerRadius="{ThemeResource OverlayCornerRadius}">
            <Image
                x:Name="PreviewImage"
                AutomationProperties.Name="GIF frame preview"
                Stretch="Uniform" />
        </Grid>

        <!--  Trim range  -->
        <StackPanel
            Grid.Row="2"
            Margin="16,0,16,12"
            Spacing="8">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    HorizontalAlignment="Left"
                    Style="{StaticResource CaptionTextBlockStyle}">
                    <Run Text="Start frame: " /><Run x:Name="StartLabel" Text="1" />
                </TextBlock>
                <TextBlock
                    x:Name="CountLabel"
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="0 frames" />
                <TextBlock
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    Style="{StaticResource CaptionTextBlockStyle}">
                    <Run Text="End frame: " /><Run x:Name="EndLabel" Text="1" />
                </TextBlock>
            </Grid>

            <local:TrimBar
                x:Name="TrimBar"
                Margin="0,6,0,2"
                AutomationProperties.AutomationId="GifTrimBar"
                AutomationProperties.Name="Trim frame range and current frame"
                EndFractionChanged="OnTrimEndChanged"
                RangeChanged="OnTrimRangeChanged"
                SeekRequested="OnTrimSeek"
                StartFractionChanged="OnTrimStartChanged" />

            <!--  Current frame stepper: step through frames and export the one shown.  -->
            <Grid Margin="0,4,0,0" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button
                    x:Name="PrevFrameButton"
                    Grid.Column="0"
                    AutomationProperties.AutomationId="GifPrevFrameButton"
                    AutomationProperties.Name="Previous frame"
                    Click="OnPrevFrame"
                    ToolTipService.ToolTip="Previous frame">
                    <FontIcon FontSize="14" Glyph="&#xE76B;" />
                </Button>
                <Button
                    x:Name="NextFrameButton"
                    Grid.Column="1"
                    AutomationProperties.AutomationId="GifNextFrameButton"
                    AutomationProperties.Name="Next frame"
                    Click="OnNextFrame"
                    ToolTipService.ToolTip="Next frame">
                    <FontIcon FontSize="14" Glyph="&#xE76C;" />
                </Button>
                <TextBlock
                    x:Name="CurrentLabel"
                    Grid.Column="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="Frame 1 / 1" />
                <Button
                    x:Name="ExportFrameButton"
                    Grid.Column="3"
                    AutomationProperties.AutomationId="GifExportFrameButton"
                    AutomationProperties.Name="Export current frame as PNG"
                    Click="OnExportFrame"
                    ToolTipService.ToolTip="Export the current frame as a PNG image">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE722;" />
                        <TextBlock Text="Export frame" />
                    </StackPanel>
                </Button>
            </Grid>

            <ProgressBar
                x:Name="BusyBar"
                Margin="0,4,0,0"
                IsIndeterminate="True"
                Visibility="Collapsed" />
        </StackPanel>

        <!--  Footer: speed + primary actions  -->
        <Grid
            Grid.Row="3"
            Margin="16,0,16,16"
            Padding="16,12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            ColumnSpacing="16"
            CornerRadius="{ThemeResource OverlayCornerRadius}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <ToggleButton
                    x:Name="PlayToggle"
                    AutomationProperties.AutomationId="GifPlayToggle"
                    AutomationProperties.Name="Play preview"
                    Checked="OnPlayToggled"
                    Unchecked="OnPlayToggled"
                    ToolTipService.ToolTip="Preview playback of the selected frame range">
                    <FontIcon FontSize="14" Glyph="&#xE768;" />
                </ToggleButton>
                <TextBlock
                    VerticalAlignment="Center"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="Speed" />
                <ComboBox
                    x:Name="SpeedCombo"
                    MinWidth="96"
                    AutomationProperties.AutomationId="GifSpeedCombo"
                    AutomationProperties.Name="Output speed"
                    SelectionChanged="OnSpeedChanged"
                    ToolTipService.ToolTip="Scales the playback speed of the saved GIF by adjusting per-frame delays.">
                    <ComboBoxItem Content="0.1x" Tag="0.1" />
                    <ComboBoxItem Content="0.25x" Tag="0.25" />
                    <ComboBoxItem Content="0.5x" Tag="0.5" />
                    <ComboBoxItem Content="0.75x" Tag="0.75" />
                    <ComboBoxItem Content="1x" Tag="1" />
                    <ComboBoxItem Content="1.25x" Tag="1.25" />
                    <ComboBoxItem Content="1.5x" Tag="1.5" />
                    <ComboBoxItem Content="1.75x" Tag="1.75" />
                    <ComboBoxItem Content="2x" Tag="2" />
                    <ComboBoxItem Content="2.5x" Tag="2.5" />
                    <ComboBoxItem Content="3x" Tag="3" />
                    <ComboBoxItem Content="4x" Tag="4" />
                    <ComboBoxItem Content="5x" Tag="5" />
                </ComboBox>
            </StackPanel>

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    AutomationProperties.AutomationId="GifTrimmerCloseButton"
                    Click="OnDone"
                    Content="Cancel" />
                <Button
                    AutomationProperties.AutomationId="GifSaveOriginalButton"
                    Click="OnDone"
                    Content="Keep original" />
                <Button
                    x:Name="SaveTrimmedButton"
                    AutomationProperties.AutomationId="GifSaveTrimmedButton"
                    Click="OnSaveTrimmed"
                    Content="Save trimmed"
                    Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
