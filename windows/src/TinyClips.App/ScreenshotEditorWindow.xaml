<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TinyClips.App.ScreenshotEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TinyClips.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Tiny Clips — Edit Screenshot"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Height="48"
            Padding="16,0">
            <TextBlock
                VerticalAlignment="Center"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="Edit screenshot" />
        </Grid>

        <!--  Output actions  -->
        <Border
            Grid.Row="1"
            Margin="16,0,16,10"
            Padding="4"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="{ThemeResource ControlCornerRadius}">
            <CommandBar
                Background="Transparent"
                DefaultLabelPosition="Right"
                IsOpen="False">
                <AppBarButton
                    x:Name="ApplyCropButton"
                    AutomationProperties.AutomationId="EditorApplyCropButton"
                    Click="OnApplyCrop"
                    Icon="Crop"
                    IsEnabled="False"
                    Label="Apply crop"
                    ToolTipService.ToolTip="Apply crop" />
                <AppBarButton
                    x:Name="UndoButton"
                    AutomationProperties.AutomationId="EditorUndoButton"
                    Click="OnUndo"
                    Label="Undo"
                    ToolTipService.ToolTip="Undo (Ctrl+Z)">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE7A7;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton
                    x:Name="DeleteButton"
                    AutomationProperties.AutomationId="EditorDeleteButton"
                    Click="OnDeleteSelected"
                    Icon="Delete"
                    Label="Delete"
                    ToolTipService.ToolTip="Delete selected (Del)" />
                <AppBarButton
                    x:Name="ResetButton"
                    AutomationProperties.AutomationId="EditorResetButton"
                    Click="OnReset"
                    Icon="Refresh"
                    Label="Reset"
                    ToolTipService.ToolTip="Reset all edits" />
                <AppBarSeparator />
                <AppBarButton
                    AutomationProperties.AutomationId="EditorCopyButton"
                    Click="OnCopy"
                    Icon="Copy"
                    Label="Copy"
                    ToolTipService.ToolTip="Copy to clipboard" />
                <AppBarButton
                    AutomationProperties.AutomationId="EditorSaveButton"
                    Click="OnSave"
                    Icon="Save"
                    Label="Save"
                    ToolTipService.ToolTip="Save" />
                <AppBarButton
                    AutomationProperties.AutomationId="EditorSaveCopyButton"
                    Click="OnSaveCopy"
                    Icon="SaveLocal"
                    Label="Save a copy"
                    ToolTipService.ToolTip="Save a copy" />
            </CommandBar>
        </Border>

        <!--  Content: tool rail | inspector | canvas  -->
        <Grid Grid.Row="2" Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Vertical tool rail  -->
            <Border
                Grid.Column="0"
                Padding="6"
                VerticalAlignment="Stretch"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{ThemeResource ControlCornerRadius}">
                <ScrollViewer
                    HorizontalScrollMode="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    ZoomMode="Disabled">
                <StackPanel Spacing="3">
                    <ToggleButton
                        x:Name="ToolSelect"
                        Width="40"
                        Height="40"
                        AutomationProperties.AutomationId="EditorToolSelect"
                        AutomationProperties.Name="Select and move"
                        Click="OnToolClick"
                        Tag="Select"
                        ToolTipService.ToolTip="Select / Move (V)">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8B0;" />
                    </ToggleButton>
                    <ToggleButton
                        x:Name="ToolCrop"
                        Width="40"
                        Height="40"
                        AutomationProperties.AutomationId="EditorToolCrop"
                        AutomationProperties.Name="Crop"
                        Click="OnToolClick"
                        Tag="Crop"
                        ToolTipService.ToolTip="Crop (C)">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE7A8;" />
                    </ToggleButton>
                    <Rectangle
                        Height="1"
                        Margin="4,3"
                        Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <ToggleButton
                        x:Name="ToolRectangle"
                        Width="40"
                        Height="40"
                        AutomationProperties.AutomationId="EditorToolRectangle"
                        AutomationProperties.Name="Rectangle"
                        Click="OnToolClick"
                        Tag="Rectangle"
                        ToolTipService.ToolTip="Rectangle (R) — hold Shift for square">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE71A;" />
                    </ToggleButton>
                    <ToggleButton
                        x:Name="ToolEllipse"
                        Width="40"
                        Height="40"
                        AutomationProperties.AutomationId="EditorToolEllipse"
                        AutomationProperties.Name="Ellipse"
                        Click="OnToolClick"
                        Tag="Ellipse"
                        ToolTipService.ToolTip="Ellipse (O) — hold Shift for circle">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xEA3A;" />
                    </ToggleButton>
                    <ToggleButton
                        x:Name="ToolArrow"
                        Width="40"
                        Height="40"
                        AutomationProperties.AutomationId="EditorToolArrow"
                        AutomationProperties.Name="Arrow"
                        Click="OnToolClick"
                        Tag="Arrow"
                        ToolTipService.ToolTip="Arrow (A) — drag any direction">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE72A;" />
                    </ToggleButton>
                    <ToggleButton
                        x:Name="ToolLine"
                        Width="40"
                        Height="40"
                        AutomationProperties.AutomationId="EditorToolLine"
                        AutomationProperties.Name="Line"
                        Click="OnToolClick"
                        Tag="Line"
                        ToolTipService.ToolTip="Line (L) — hold Shift to snap">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE738;" />
                    </ToggleButton>
                    <ToggleButton
                        x:Name="ToolPen"
                        Width="40"
                        Height="40"
                        AutomationProperties.AutomationId="EditorToolPen"
                        AutomationProperties.Name="Draw"
                        Click="OnToolClick"
                        Tag="Pen"
                        ToolTipService.ToolTip="Draw (D)">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE70F;" />
                    </ToggleButton>
                    <ToggleButton
                        x:Name="ToolText"
                        Width="40"
                        Height="40"
                        AutomationProperties.AutomationId="EditorToolText"
                        AutomationProperties.Name="Text"
                        Click="OnToolClick"
                        Tag="Text"
                        ToolTipService.ToolTip="Text (T)">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8D2;" />
                    </ToggleButton>
                    <ToggleButton
                        x:Name="ToolCounter"
                        Width="40"
                        Height="40"
                        AutomationProperties.AutomationId="EditorToolCounter"
                        AutomationProperties.Name="Number badge"
                        Click="OnToolClick"
                        Tag="Counter"
                        ToolTipService.ToolTip="Number (N)">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8EF;" />
                    </ToggleButton>
                    <ToggleButton
                        x:Name="ToolRedact"
                        Width="40"
                        Height="40"
                        AutomationProperties.AutomationId="EditorToolRedact"
                        AutomationProperties.Name="Redact"
                        Click="OnToolClick"
                        Tag="Redact"
                        ToolTipService.ToolTip="Redact / Blur (B)">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xED1A;" />
                    </ToggleButton>
                </StackPanel>
                </ScrollViewer>
            </Border>

            <!--  Inspector  -->
            <Border
                Grid.Column="1"
                Width="252"
                Margin="12,0,12,0"
                VerticalAlignment="Stretch"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{ThemeResource ControlCornerRadius}">
                <ScrollViewer HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Padding="14" Spacing="14">
                        <TextBlock
                            x:Name="InspectorTitle"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="Tool" />

                        <!--  Color  -->
                        <StackPanel x:Name="ColorSection" Spacing="6">
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="Color" />
                            <Button
                                x:Name="ColorButton"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                AutomationProperties.AutomationId="EditorColorButton"
                                AutomationProperties.Name="Color">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border
                                        x:Name="ColorSwatch"
                                        Width="22"
                                        Height="22"
                                        Background="Red"
                                        CornerRadius="4" />
                                    <TextBlock VerticalAlignment="Center" Text="Pick color" />
                                </StackPanel>
                                <Button.Flyout>
                                    <Flyout>
                                        <ColorPicker
                                            x:Name="AnnotationColorPicker"
                                            ColorChanged="OnColorChanged"
                                            ColorSpectrumShape="Ring"
                                            IsAlphaEnabled="False"
                                            IsColorChannelTextInputVisible="False"
                                            IsHexInputVisible="True" />
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>

                        <!--  Stroke width  -->
                        <StackPanel x:Name="StrokeSection" Spacing="2">
                            <Slider
                                x:Name="StrokeSlider"
                                AutomationProperties.AutomationId="EditorStrokeSlider"
                                AutomationProperties.Name="Stroke width"
                                Header="Stroke"
                                Maximum="40"
                                Minimum="1"
                                StepFrequency="1"
                                ValueChanged="OnStrokeChanged" />
                        </StackPanel>

                        <!--  Fill (rectangle / ellipse)  -->
                        <StackPanel x:Name="FillSection" Spacing="6">
                            <CheckBox
                                x:Name="FillCheck"
                                AutomationProperties.AutomationId="EditorFillCheck"
                                AutomationProperties.Name="Fill shape"
                                Checked="OnFillToggled"
                                Content="Fill shape"
                                Unchecked="OnFillToggled" />
                            <Button
                                x:Name="FillColorButton"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                AutomationProperties.AutomationId="EditorFillColorButton"
                                AutomationProperties.Name="Fill color">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border
                                        x:Name="FillColorSwatch"
                                        Width="22"
                                        Height="22"
                                        Background="Transparent"
                                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4" />
                                    <TextBlock VerticalAlignment="Center" Text="Fill color" />
                                </StackPanel>
                                <Button.Flyout>
                                    <Flyout>
                                        <ColorPicker
                                            x:Name="FillColorPicker"
                                            ColorChanged="OnFillColorChanged"
                                            ColorSpectrumShape="Ring"
                                            IsAlphaEnabled="True"
                                            IsColorChannelTextInputVisible="False"
                                            IsHexInputVisible="True" />
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>

                        <!--  Text  -->
                        <StackPanel x:Name="TextSection" Spacing="10">
                            <ComboBox
                                x:Name="FontFamilyCombo"
                                HorizontalAlignment="Stretch"
                                AutomationProperties.AutomationId="EditorFontFamilyCombo"
                                AutomationProperties.Name="Font"
                                Header="Font"
                                SelectionChanged="OnFontFamilyChanged" />
                            <Slider
                                x:Name="FontSizeSlider"
                                AutomationProperties.AutomationId="EditorFontSizeSlider"
                                AutomationProperties.Name="Font size"
                                Header="Font size"
                                Maximum="200"
                                Minimum="10"
                                StepFrequency="1"
                                ValueChanged="OnFontSizeChanged" />
                        </StackPanel>

                        <!--  Number badge  -->
                        <StackPanel x:Name="CounterSection" Spacing="10">
                            <Slider
                                x:Name="NumberSizeSlider"
                                AutomationProperties.AutomationId="EditorNumberSizeSlider"
                                AutomationProperties.Name="Badge size"
                                Header="Badge size"
                                Maximum="4"
                                Minimum="0.5"
                                StepFrequency="0.25"
                                ValueChanged="OnNumberSizeChanged" />
                            <StackPanel Spacing="6">
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="Number color" />
                                <Button
                                    x:Name="NumberColorButton"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    AutomationProperties.AutomationId="EditorNumberColorButton"
                                    AutomationProperties.Name="Number color">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Border
                                            x:Name="NumberColorSwatch"
                                            Width="22"
                                            Height="22"
                                            Background="White"
                                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4" />
                                        <TextBlock VerticalAlignment="Center" Text="Pick color" />
                                    </StackPanel>
                                    <Button.Flyout>
                                        <Flyout>
                                            <ColorPicker
                                                x:Name="NumberColorPicker"
                                                ColorChanged="OnNumberColorChanged"
                                                ColorSpectrumShape="Ring"
                                                IsAlphaEnabled="False"
                                                IsColorChannelTextInputVisible="False"
                                                IsHexInputVisible="True" />
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!--  Redaction strength  -->
                        <StackPanel x:Name="RedactSection" Spacing="2">
                            <ComboBox
                                x:Name="RedactionCombo"
                                HorizontalAlignment="Stretch"
                                AutomationProperties.AutomationId="EditorRedactionCombo"
                                AutomationProperties.Name="Redaction strength"
                                Header="Blur strength"
                                SelectionChanged="OnRedactionLevelChanged">
                                <ComboBoxItem Content="Light" Tag="Light" />
                                <ComboBoxItem Content="Medium" Tag="Medium" />
                                <ComboBoxItem Content="Heavy" Tag="Heavy" />
                            </ComboBox>
                        </StackPanel>

                        <!--  Background &amp; padding  -->
                        <Expander
                            x:Name="BackgroundExpander"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            AutomationProperties.AutomationId="EditorBackgroundExpander">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="16" Glyph="&#xE7F4;" />
                                    <TextBlock VerticalAlignment="Center" Text="Background" />
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Width="200" Spacing="12">
                                <ComboBox
                                    x:Name="BgStyleCombo"
                                    HorizontalAlignment="Stretch"
                                    AutomationProperties.AutomationId="EditorBgStyleCombo"
                                    AutomationProperties.Name="Background style"
                                    Header="Style"
                                    SelectionChanged="OnBgStyleChanged">
                                    <ComboBoxItem Content="Transparent" Tag="Transparent" />
                                    <ComboBoxItem Content="Solid color" Tag="Solid" />
                                    <ComboBoxItem Content="Gradient" Tag="Gradient" />
                                </ComboBox>

                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="Solid presets" />
                                <GridView
                                    x:Name="SolidPresetGrid"
                                    Padding="0"
                                    AutomationProperties.Name="Solid background presets"
                                    SelectionMode="None" />

                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="Gradient presets" />
                                <GridView
                                    x:Name="GradientPresetGrid"
                                    Padding="0"
                                    AutomationProperties.Name="Gradient background presets"
                                    SelectionMode="None" />

                                <StackPanel x:Name="CustomColorPanel" Spacing="8">
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="Custom color" />
                                    <ColorPicker
                                        x:Name="BgColorPicker"
                                        ColorChanged="OnBgCustomColorChanged"
                                        ColorSpectrumShape="Box"
                                        IsAlphaEnabled="False"
                                        IsColorPreviewVisible="True"
                                        IsColorSliderVisible="True"
                                        IsHexInputVisible="True"
                                        IsMoreButtonVisible="False" />
                                    <Button
                                        HorizontalAlignment="Stretch"
                                        AutomationProperties.AutomationId="EditorApplyCustomBgButton"
                                        Click="OnApplyCustomSolidBackground"
                                        Content="Use as solid background" />
                                </StackPanel>

                                <Slider
                                    x:Name="PaddingSlider"
                                    AutomationProperties.AutomationId="EditorPaddingSlider"
                                    AutomationProperties.Name="Padding"
                                    Header="Padding"
                                    Maximum="160"
                                    Minimum="0"
                                    StepFrequency="2"
                                    ValueChanged="OnPaddingChanged" />
                                <Slider
                                    x:Name="CornerSlider"
                                    AutomationProperties.AutomationId="EditorCornerSlider"
                                    AutomationProperties.Name="Corner radius"
                                    Header="Corners"
                                    Maximum="60"
                                    Minimum="0"
                                    StepFrequency="1"
                                    ValueChanged="OnCornerChanged" />
                                <Slider
                                    x:Name="ShadowSlider"
                                    AutomationProperties.AutomationId="EditorShadowSlider"
                                    AutomationProperties.Name="Shadow"
                                    Header="Shadow"
                                    Maximum="40"
                                    Minimum="0"
                                    StepFrequency="1"
                                    ValueChanged="OnShadowChanged" />
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!--  Canvas  -->
            <Grid
                x:Name="ImageHost"
                Grid.Column="2"
                Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                CornerRadius="{ThemeResource OverlayCornerRadius}"
                SizeChanged="OnImageHostSizeChanged">
                <Canvas x:Name="CanvasLayer" IsHitTestVisible="False">
                    <Border
                        x:Name="CanvasBackground"
                        Visibility="Collapsed" />
                    <Border x:Name="ImageCard">
                        <Image
                            x:Name="PreviewImage"
                            Stretch="Fill" />
                    </Border>
                </Canvas>
                <Canvas
                    x:Name="OverlayCanvas"
                    Background="Transparent"
                    PointerMoved="OnPointerMoved"
                    PointerPressed="OnPointerPressed"
                    PointerReleased="OnPointerReleased">
                    <Rectangle
                        x:Name="SelectionRect"
                        Fill="{ThemeResource AccentFillColorDefaultBrush}"
                        Opacity="0.25"
                        Stroke="{ThemeResource AccentFillColorDefaultBrush}"
                        StrokeDashArray="4,2"
                        StrokeThickness="2"
                        Visibility="Collapsed" />
                    <TextBox
                        x:Name="TextEditBox"
                        MinWidth="120"
                        Padding="6,2"
                        AcceptsReturn="False"
                        AutomationProperties.AutomationId="EditorTextEntry"
                        Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                        BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                        BorderThickness="2"
                        FontSize="16"
                        GotFocus="OnTextEntryGotFocus"
                        KeyDown="OnTextEntryKeyDown"
                        LostFocus="OnTextEntryCommitted"
                        Visibility="Collapsed" />
                </Canvas>
                <TextBlock
                    x:Name="HintText"
                    Margin="0,0,0,12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="Pick a tool, then draw on the image. Crop, annotate, then save." />
            </Grid>
        </Grid>
    </Grid>
</Window>
