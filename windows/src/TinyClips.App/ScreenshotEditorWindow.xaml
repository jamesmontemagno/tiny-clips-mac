<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TinyClips.App.ScreenshotEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TinyClips.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Tiny Clips — Edit Screenshot"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Height="48"
            Padding="16,0">
            <TextBlock
                VerticalAlignment="Center"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="Edit screenshot" />
        </Grid>

        <!--  Tool strip  -->
        <Border
            Grid.Row="1"
            Margin="16,0,16,0"
            Padding="6"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="{ThemeResource ControlCornerRadius}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Tools  -->
                <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="2">
                    <ToggleButton
                        x:Name="ToolSelect"
                        AutomationProperties.AutomationId="EditorToolSelect"
                        AutomationProperties.Name="Select and move"
                        Click="OnToolClick"
                        Tag="Select"
                        ToolTipService.ToolTip="Select / Move (V)">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8B0;" />
                    </ToggleButton>
                    <ToggleButton
                        x:Name="ToolCrop"
                        AutomationProperties.AutomationId="EditorToolCrop"
                        AutomationProperties.Name="Crop"
                        Click="OnToolClick"
                        Tag="Crop"
                        ToolTipService.ToolTip="Crop (C)">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE7A8;" />
                    </ToggleButton>
                    <AppBarSeparator Width="1" />
                    <ToggleButton
                        x:Name="ToolRectangle"
                        AutomationProperties.AutomationId="EditorToolRectangle"
                        AutomationProperties.Name="Rectangle"
                        Click="OnToolClick"
                        Tag="Rectangle"
                        ToolTipService.ToolTip="Rectangle (R)">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE71A;" />
                    </ToggleButton>
                    <ToggleButton
                        x:Name="ToolEllipse"
                        AutomationProperties.AutomationId="EditorToolEllipse"
                        AutomationProperties.Name="Ellipse"
                        Click="OnToolClick"
                        Tag="Ellipse"
                        ToolTipService.ToolTip="Ellipse (O)">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xEA3A;" />
                    </ToggleButton>
                    <ToggleButton
                        x:Name="ToolArrow"
                        AutomationProperties.AutomationId="EditorToolArrow"
                        AutomationProperties.Name="Arrow"
                        Click="OnToolClick"
                        Tag="Arrow"
                        ToolTipService.ToolTip="Arrow (A)">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE72A;" />
                    </ToggleButton>
                    <ToggleButton
                        x:Name="ToolLine"
                        AutomationProperties.AutomationId="EditorToolLine"
                        AutomationProperties.Name="Line"
                        Click="OnToolClick"
                        Tag="Line"
                        ToolTipService.ToolTip="Line (L)">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE738;" />
                    </ToggleButton>
                    <ToggleButton
                        x:Name="ToolPen"
                        AutomationProperties.AutomationId="EditorToolPen"
                        AutomationProperties.Name="Draw"
                        Click="OnToolClick"
                        Tag="Pen"
                        ToolTipService.ToolTip="Draw (D)">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE70F;" />
                    </ToggleButton>
                    <ToggleButton
                        x:Name="ToolText"
                        AutomationProperties.AutomationId="EditorToolText"
                        AutomationProperties.Name="Text"
                        Click="OnToolClick"
                        Tag="Text"
                        ToolTipService.ToolTip="Text (T)">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8D2;" />
                    </ToggleButton>
                    <ToggleButton
                        x:Name="ToolCounter"
                        AutomationProperties.AutomationId="EditorToolCounter"
                        AutomationProperties.Name="Number badge"
                        Click="OnToolClick"
                        Tag="Counter"
                        ToolTipService.ToolTip="Number (N)">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8EF;" />
                    </ToggleButton>
                    <ToggleButton
                        x:Name="ToolRedact"
                        AutomationProperties.AutomationId="EditorToolRedact"
                        AutomationProperties.Name="Redact"
                        Click="OnToolClick"
                        Tag="Redact"
                        ToolTipService.ToolTip="Redact / Blur (B)">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xED1A;" />
                    </ToggleButton>

                    <AppBarSeparator Width="1" />

                    <!--  Color  -->
                    <Button
                        x:Name="ColorButton"
                        Width="40"
                        AutomationProperties.AutomationId="EditorColorButton"
                        AutomationProperties.Name="Color"
                        ToolTipService.ToolTip="Color">
                        <Border
                            x:Name="ColorSwatch"
                            Width="20"
                            Height="20"
                            Background="Red"
                            CornerRadius="4" />
                        <Button.Flyout>
                            <Flyout>
                                <ColorPicker
                                    x:Name="AnnotationColorPicker"
                                    ColorChanged="OnColorChanged"
                                    ColorSpectrumShape="Ring"
                                    IsAlphaEnabled="False"
                                    IsColorChannelTextInputVisible="False"
                                    IsHexInputVisible="True" />
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <!--  Stroke thickness (shapes / line / arrow / pen / text)  -->
                    <ComboBox
                        x:Name="ThicknessCombo"
                        Width="96"
                        Margin="4,0,0,0"
                        VerticalAlignment="Center"
                        AutomationProperties.AutomationId="EditorThicknessCombo"
                        AutomationProperties.Name="Stroke thickness"
                        SelectionChanged="OnThicknessChanged"
                        ToolTipService.ToolTip="Thickness">
                        <ComboBoxItem Content="1 px" Tag="1" />
                        <ComboBoxItem Content="2 px" Tag="2" />
                        <ComboBoxItem Content="4 px" Tag="4" />
                        <ComboBoxItem Content="6 px" Tag="6" />
                        <ComboBoxItem Content="8 px" Tag="8" />
                        <ComboBoxItem Content="10 px" Tag="10" />
                    </ComboBox>

                    <!--  Number badge size (counter tool)  -->
                    <ComboBox
                        x:Name="NumberSizeCombo"
                        Width="96"
                        Margin="4,0,0,0"
                        VerticalAlignment="Center"
                        AutomationProperties.AutomationId="EditorNumberSizeCombo"
                        AutomationProperties.Name="Number size"
                        SelectionChanged="OnNumberSizeChanged"
                        ToolTipService.ToolTip="Badge size"
                        Visibility="Collapsed">
                        <ComboBoxItem Content="50%" Tag="0.5" />
                        <ComboBoxItem Content="75%" Tag="0.75" />
                        <ComboBoxItem Content="100%" Tag="1.0" />
                        <ComboBoxItem Content="125%" Tag="1.25" />
                        <ComboBoxItem Content="150%" Tag="1.5" />
                        <ComboBoxItem Content="200%" Tag="2.0" />
                    </ComboBox>

                    <!--  Redaction strength (redact tool)  -->
                    <ComboBox
                        x:Name="RedactionCombo"
                        Width="104"
                        Margin="4,0,0,0"
                        VerticalAlignment="Center"
                        AutomationProperties.AutomationId="EditorRedactionCombo"
                        AutomationProperties.Name="Redaction strength"
                        SelectionChanged="OnRedactionLevelChanged"
                        ToolTipService.ToolTip="Blur strength"
                        Visibility="Collapsed">
                        <ComboBoxItem Content="Light" Tag="Light" />
                        <ComboBoxItem Content="Medium" Tag="Medium" />
                        <ComboBoxItem Content="Heavy" Tag="Heavy" />
                    </ComboBox>

                    <AppBarSeparator Width="1" />

                    <Button
                        x:Name="UndoButton"
                        AutomationProperties.AutomationId="EditorUndoButton"
                        AutomationProperties.Name="Undo"
                        Click="OnUndo"
                        ToolTipService.ToolTip="Undo (Ctrl+Z)">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE7A7;" />
                    </Button>
                    <Button
                        x:Name="DeleteButton"
                        AutomationProperties.AutomationId="EditorDeleteButton"
                        AutomationProperties.Name="Delete selected"
                        Click="OnDeleteSelected"
                        ToolTipService.ToolTip="Delete selected (Del)">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE74D;" />
                    </Button>

                    <AppBarSeparator Width="1" />

                    <Button
                        x:Name="BackgroundButton"
                        AutomationProperties.AutomationId="EditorBackgroundButton"
                        AutomationProperties.Name="Background and padding"
                        ToolTipService.ToolTip="Background &amp; padding">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE7F4;" />
                            <TextBlock VerticalAlignment="Center" Text="Background" />
                        </StackPanel>
                        <Button.Flyout>
                            <Flyout>
                                <ScrollViewer
                                    MaxHeight="540"
                                    HorizontalScrollMode="Disabled"
                                    VerticalScrollBarVisibility="Auto">
                                    <StackPanel Width="288" Spacing="12">
                                        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Background" />
                                        <ComboBox
                                            x:Name="BgStyleCombo"
                                            HorizontalAlignment="Stretch"
                                            AutomationProperties.AutomationId="EditorBgStyleCombo"
                                            AutomationProperties.Name="Background style"
                                            Header="Style"
                                            SelectionChanged="OnBgStyleChanged">
                                            <ComboBoxItem Content="Transparent" Tag="Transparent" />
                                            <ComboBoxItem Content="Solid color" Tag="Solid" />
                                            <ComboBoxItem Content="Gradient" Tag="Gradient" />
                                        </ComboBox>

                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="Solid presets" />
                                        <GridView
                                            x:Name="SolidPresetGrid"
                                            Padding="0"
                                            AutomationProperties.Name="Solid background presets"
                                            SelectionMode="None" />

                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="Gradient presets" />
                                        <GridView
                                            x:Name="GradientPresetGrid"
                                            Padding="0"
                                            AutomationProperties.Name="Gradient background presets"
                                            SelectionMode="None" />

                                        <StackPanel x:Name="CustomColorPanel" Spacing="12">
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="Custom color" />
                                            <ColorPicker
                                                x:Name="BgColorPicker"
                                                ColorChanged="OnBgCustomColorChanged"
                                                ColorSpectrumShape="Box"
                                                IsAlphaEnabled="False"
                                                IsColorPreviewVisible="True"
                                                IsColorSliderVisible="True"
                                                IsHexInputVisible="True"
                                                IsMoreButtonVisible="False" />
                                            <Button
                                                HorizontalAlignment="Stretch"
                                                AutomationProperties.AutomationId="EditorApplyCustomBgButton"
                                                Click="OnApplyCustomSolidBackground"
                                                Content="Use as solid background" />
                                        </StackPanel>

                                        <Slider
                                            x:Name="PaddingSlider"
                                            AutomationProperties.AutomationId="EditorPaddingSlider"
                                            AutomationProperties.Name="Padding"
                                            Header="Padding"
                                            Maximum="160"
                                            Minimum="0"
                                            StepFrequency="2"
                                            ValueChanged="OnPaddingChanged" />
                                        <Slider
                                            x:Name="CornerSlider"
                                            AutomationProperties.AutomationId="EditorCornerSlider"
                                            AutomationProperties.Name="Corner radius"
                                            Header="Corners"
                                            Maximum="60"
                                            Minimum="0"
                                            StepFrequency="1"
                                            ValueChanged="OnCornerChanged" />
                                        <Slider
                                            x:Name="ShadowSlider"
                                            AutomationProperties.AutomationId="EditorShadowSlider"
                                            AutomationProperties.Name="Shadow"
                                            Header="Shadow"
                                            Maximum="40"
                                            Minimum="0"
                                            StepFrequency="1"
                                            ValueChanged="OnShadowChanged" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>

                <!--  Output actions  -->
                <CommandBar
                    Grid.Column="1"
                    Background="Transparent"
                    DefaultLabelPosition="Collapsed"
                    IsOpen="False">
                    <AppBarButton
                        x:Name="ApplyCropButton"
                        AutomationProperties.AutomationId="EditorApplyCropButton"
                        Click="OnApplyCrop"
                        Icon="Crop"
                        IsEnabled="False"
                        Label="Apply crop"
                        ToolTipService.ToolTip="Apply crop" />
                    <AppBarButton
                        x:Name="ResetButton"
                        AutomationProperties.AutomationId="EditorResetButton"
                        Click="OnReset"
                        Icon="Refresh"
                        Label="Reset"
                        ToolTipService.ToolTip="Reset all edits" />
                    <AppBarSeparator />
                    <AppBarButton
                        AutomationProperties.AutomationId="EditorCopyButton"
                        Click="OnCopy"
                        Icon="Copy"
                        Label="Copy"
                        ToolTipService.ToolTip="Copy to clipboard" />
                    <AppBarButton
                        AutomationProperties.AutomationId="EditorSaveButton"
                        Click="OnSave"
                        Icon="Save"
                        Label="Save"
                        ToolTipService.ToolTip="Save" />
                    <AppBarButton
                        AutomationProperties.AutomationId="EditorSaveCopyButton"
                        Click="OnSaveCopy"
                        Icon="SaveLocal"
                        Label="Save a copy"
                        ToolTipService.ToolTip="Save a copy" />
                </CommandBar>
            </Grid>
        </Border>

        <!--  Canvas  -->
        <Grid
            x:Name="ImageHost"
            Grid.Row="3"
            Margin="16"
            Background="{ThemeResource SubtleFillColorTertiaryBrush}"
            CornerRadius="{ThemeResource OverlayCornerRadius}"
            SizeChanged="OnImageHostSizeChanged">
            <Canvas x:Name="CanvasLayer" IsHitTestVisible="False">
                <Border
                    x:Name="CanvasBackground"
                    Visibility="Collapsed" />
                <Border x:Name="ImageCard">
                    <Image
                        x:Name="PreviewImage"
                        Stretch="Fill" />
                </Border>
            </Canvas>
            <Canvas
                x:Name="OverlayCanvas"
                Background="Transparent"
                PointerMoved="OnPointerMoved"
                PointerPressed="OnPointerPressed"
                PointerReleased="OnPointerReleased">
                <Rectangle
                    x:Name="SelectionRect"
                    Fill="{ThemeResource AccentFillColorDefaultBrush}"
                    Opacity="0.25"
                    Stroke="{ThemeResource AccentFillColorDefaultBrush}"
                    StrokeDashArray="4,2"
                    StrokeThickness="2"
                    Visibility="Collapsed" />
                <TextBox
                    x:Name="TextEditBox"
                    MinWidth="80"
                    AcceptsReturn="False"
                    AutomationProperties.AutomationId="EditorTextEntry"
                    FontSize="16"
                    GotFocus="OnTextEntryGotFocus"
                    KeyDown="OnTextEntryKeyDown"
                    LostFocus="OnTextEntryCommitted"
                    Visibility="Collapsed" />
            </Canvas>
            <TextBlock
                x:Name="HintText"
                Margin="0,0,0,12"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="Pick a tool, then draw on the image. Crop, annotate, then save." />
        </Grid>
    </Grid>
</Window>
