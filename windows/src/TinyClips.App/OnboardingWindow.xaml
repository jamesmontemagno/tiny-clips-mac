<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TinyClips.App.OnboardingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TinyClips.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Welcome to Tiny Clips"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Height="48"
            Padding="16,0"
            ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                VerticalAlignment="Center"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="Welcome" />
            <Button
                Grid.Column="1"
                AutomationProperties.AutomationId="OnboardingSkipButton"
                Background="Transparent"
                BorderThickness="0"
                Click="OnSkipClicked"
                Content="Skip" />
        </Grid>

        <!--  Steps  -->
        <Grid Grid.Row="1" Padding="48,16">
            <!--  Step 0: Welcome  -->
            <StackPanel
                x:Name="Step0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16">
                <Border
                    Width="88"
                    Height="88"
                    HorizontalAlignment="Center"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    CornerRadius="20">
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        FontSize="44"
                        Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                        Glyph="&#xE722;" />
                </Border>
                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource TitleLargeTextBlockStyle}"
                    Text="Welcome to Tiny Clips" />
                <TextBlock
                    MaxWidth="440"
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Text="A tiny tray app for fast screenshots, screen recordings, and GIFs. Let's take a quick tour."
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>

            <!--  Step 1: How it works  -->
            <StackPanel
                x:Name="Step1"
                MaxWidth="480"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16"
                Visibility="Collapsed">
                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="Three ways to capture" />
                <local:GuideRow
                    Glyph="&#xE722;"
                    Subtitle="Snap a region, window, or full screen to a PNG or JPEG."
                    Title="Screenshot" />
                <local:GuideRow
                    Glyph="&#xE714;"
                    Subtitle="Record your screen to a shareable MP4 video."
                    Title="Video" />
                <local:GuideRow
                    Glyph="&#xE786;"
                    Subtitle="Capture a short looping GIF, great for chats and issues."
                    Title="GIF" />
            </StackPanel>

            <!--  Step 2: All set  -->
            <StackPanel
                x:Name="Step2"
                MaxWidth="480"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16"
                Visibility="Collapsed">
                <Border
                    Width="88"
                    Height="88"
                    HorizontalAlignment="Center"
                    Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                    CornerRadius="20">
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        FontSize="44"
                        Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                        Glyph="&#xE73E;" />
                </Border>
                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="You're all set" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Text="Use these shortcuts any time, or click the tray icon."
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
                <Border Style="{StaticResource SettingCardStyle}">
                    <StackPanel Spacing="8">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Text="Screenshot" />
                            <TextBlock
                                x:Name="ScreenshotShortcut"
                                Grid.Column="1"
                                FontFamily="Consolas" />
                        </Grid>
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Text="Record video" />
                            <TextBlock
                                x:Name="VideoShortcut"
                                Grid.Column="1"
                                FontFamily="Consolas" />
                        </Grid>
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Text="Record GIF" />
                            <TextBlock
                                x:Name="GifShortcut"
                                Grid.Column="1"
                                FontFamily="Consolas" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!--  Footer  -->
        <Grid
            Grid.Row="2"
            Padding="24,16"
            ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="BackButton"
                AutomationProperties.AutomationId="OnboardingBackButton"
                Click="OnBackClicked"
                Content="Back"
                Visibility="Collapsed" />

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <Ellipse
                    x:Name="Dot0"
                    Width="8"
                    Height="8"
                    Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                <Ellipse
                    x:Name="Dot1"
                    Width="8"
                    Height="8"
                    Fill="{ThemeResource ControlStrongFillColorDefaultBrush}" />
                <Ellipse
                    x:Name="Dot2"
                    Width="8"
                    Height="8"
                    Fill="{ThemeResource ControlStrongFillColorDefaultBrush}" />
            </StackPanel>

            <Button
                x:Name="NextButton"
                Grid.Column="2"
                AutomationProperties.AutomationId="OnboardingNextButton"
                Click="OnNextClicked"
                Content="Next"
                Style="{StaticResource AccentButtonStyle}" />
        </Grid>
    </Grid>
</Window>
