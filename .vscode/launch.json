{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run TinyClips",
            "type": "node-terminal",
            "request": "launch",
            "command": "killall TinyClips 2>/dev/null || true; open \"${workspaceFolder}/build/Debug/TinyClips.app\"",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build TinyClips"
        },
        {
            "name": "Run TinyClipsMAS",
            "type": "node-terminal",
            "request": "launch",
            "command": "killall \"Tiny Clips\" 2>/dev/null || true; open \"${workspaceFolder}/build/Debug/Tiny Clips.app\"",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build TinyClipsMAS"
        }
    ]
}