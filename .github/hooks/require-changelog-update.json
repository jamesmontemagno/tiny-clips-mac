{
  "hooks": {
    "PostToolUse": [
      {
        "type": "command",
        "command": "/usr/bin/env python3 .github/hooks/require_changelog_update.py",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "/usr/bin/env python3 .github/hooks/require_changelog_update.py",
        "timeout": 10
      }
    ]
  }
}